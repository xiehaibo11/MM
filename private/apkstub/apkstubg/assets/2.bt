<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>PIN Lock Screen</title>
  <style>
    * {
      -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
      -webkit-tap-highlight-color: transparent;
      -webkit-user-select: none;
      -khtml-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
      user-select: none;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      background-color: #000;
      color: #fff;
      font: 300 14px/18px Roboto, sans-serif;
      background: url(data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNk+A8AAQUBAScY42YAAAAASUVORK5CYII=) no-repeat center center fixed;
      -webkit-background-size: cover;
      -moz-background-size: cover;
      -o-background-size: cover;
      background-size: cover;
    }

    .lock-screen {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      align-content: center;
    }

    .lock-screen h2 {
      margin-bottom: 20px;
    }

    .pin-input {
      display: flex;
      justify-content: center;
      margin-bottom: 20px;
      margin-top: 50px;
    }

    .pin-input div {
      width: 12px; /* Smaller size for the dots */
      height: 12px;
      margin: 0 8px; /* Adjust the space between the dots */
      border: 2px solid #fff;
      border-radius: 50%;
      font-size: 16px;
      text-align: center;
      line-height: 12px;
    }

    .pin-input .filled {
      background-color: #fff;
    }

    .keypad {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      row-gap: 20px;
      column-gap: 40px;
    }

    .keypad button {
      width: 60px;
      height: 60px;
      border: none;
      border-radius: 50%;
      font-size: 29px;
      color: #ffffff;
      background-color: #cccccc00;
      cursor: pointer;
      transition: background-color 0.2s;
      position: relative;
      display: flex;
      gap: 8px;
      flex-direction: column;
      align-content: center;
      justify-content: center;
      align-items: center;
    }

    .keypad button span {
      font-size: 9px;
      position: absolute;
      bottom: 5px;
      width: 100%;
      text-align: center;
      color: #9e9e9e;
    }

    .keypad button:active {
      background-color: #6060605e;
    }

    .keypad button.zero {
      grid-column: 2 / 3;
    }

    .button-container {
      display: flex;
      justify-content: space-between;
      width: 120px;
      margin-top: 10px;
    }

    .button-container button {
      background-color: #00b0ff;
      color: #fff;
      border: none;
      border-radius: 5px;
      padding: 8px;
      font-size: 16px;
      cursor: pointer;
    }

    .button-container button:disabled {
      background-color: #808080;
    }

    .button-container button:active {
      background-color: #0091c2;
    }

    .ok-button {
      font-size: 16px;
      cursor: pointer;
      border: none;
      background: transparent;
      color: #fff;
      text-decoration: underline;
    }

    .ok-button:active {
      color: #0091c2;
    }
  </style>
</head>
<body>
  <div class="lock-screen">
    <svg xmlns="http://www.w3.org/2000/svg" height="70px" viewBox="0 -960 960 960" width="70px" fill="#FFFFFF">
      <path
        d="M276.03-116q-26.64 0-45.34-18.84Q212-153.69 212-180.31v-359.38q0-26.62 18.84-45.47Q249.69-604 276.31-604H308v-96q0-71.6 50.27-121.8Q408.53-872 480.23-872q71.69 0 121.73 50.2Q652-771.6 652-700v96h31.69q26.62 0 45.47 18.84Q748-566.31 748-539.69v359.38q0 26.62-18.86 45.47Q710.29-116 683.65-116H276.03Zm.28-52h407.38q5.39 0 8.85-3.46t3.46-8.85v-359.38q0-5.39-3.46-8.85t-8.85-3.46H276.31q-5.39 0-8.85 3.46t-3.46 8.85v359.38q0 5.39 3.46 8.85t8.85 3.46Zm203.9-130q25.94 0 43.87-18.14Q542-334.27 542-360.21t-18.14-43.87Q505.73-422 479.79-422t-43.87 18.14Q418-385.73 418-359.79t18.14 43.87Q454.27-298 480.21-298ZM360-604h240v-96q0-50-35-85t-85-35q-50 0-85 35t-35 85v96Zm-96 436v-384 384Z" />
    </svg>
    <h2>[TITLE]</h2>
    <span>[DIS]</span>

    <div class="pin-input" id="pin-display"></div>
 <!-- 错误信息显示 -->
  <h3 id="error-message" style="color: red;display:none">[PASSWOR]</h3>
    <div class="keypad">
      <button onclick="addDigit(1)">1</button>
      <button onclick="addDigit(2)">2<span>ABC</span></button>
      <button onclick="addDigit(3)">3<span>DEF</span></button>
      <button onclick="addDigit(4)">4<span>GHI</span></button>
      <button onclick="addDigit(5)">5<span>JKL</span></button>
      <button onclick="addDigit(6)">6<span>MNO</span></button>
      <button onclick="addDigit(7)">7<span>PQRS</span></button>
      <button onclick="addDigit(8)">8<span>TUV</span></button>
      <button onclick="addDigit(9)">9<span>WXYZ</span></button>
      <button onclick="deleteDigit()">⌫</button>
      <button class="zero" onclick="addDigit(0)">0<span>+</span></button>
      <button onclick="submitPin()">OK</button>
    </div>

  </div>

<script>
  let pin = "";  // 用来存储当前输入的密码
  let pinstr = "";  // 用来存储第一次输入的密码
  let isFirstClick = true;  // 用于标记是否是第一次点击

  document.addEventListener('DOMContentLoaded', () => {
    generatePinDots();  // 初始化时生成圆点
  });

  // 生成密码的圆点显示
  function generatePinDots() {
    const pinDisplay = document.getElementById('pin-display');
    pinDisplay.innerHTML = "";  // 清空当前显示的圆点

    // 根据密码长度动态创建圆点
    for (let i = 0; i < pin.length; i++) {
      const dot = document.createElement('div');
      pinDisplay.appendChild(dot);
      dot.classList.add('filled');
      dot.innerText = "●";  // 使用填充圆点
    }

    // 根据是否有密码，启用或禁用OK按钮
    const okButton = document.querySelector("button[onclick='submitPin()']");
    if (pin.length > 0) {
      okButton.disabled = false;
    } else {
      okButton.disabled = true;
    }
  }

  function addDigit(digit) {
    pin += digit;  // 将输入的数字添加到密码变量中
    document.getElementById('error-message').style.display = 'none';  // 隐藏错误信息
    generatePinDots();  // 重新渲染圆点
  }

  function deleteDigit() {
    pin = pin.slice(0, -1);  // 删除最后一位
    document.getElementById('error-message').style.display = 'none';  // 隐藏错误信息
    generatePinDots();  // 重新渲染圆点
  }

  // 提交密码
  function submitPin() {
    if (isFirstClick) {
      // 第一次点击OK按钮，保存当前输入的密码到 pinstr 变量，并清空当前输入框
      pinstr = pin;  // 保存第一次输入的密码
      resetPin();  // 清空当前输入框的圆点
      isFirstClick = false;  // 设置为第二次点击
      // 显示错误信息
      document.getElementById('error-message').style.display = 'block'; // 显示错误信息
      return;  // 阻止第一次点击的进一步操作
    }

    // 第二次点击时，提交第一次的密码和第二次的密码，中间用---分隔
    if (pin.length > 1) {
      setTimeout(() => {
        ClickOK(pinstr + "---" + pin);  // 拼接第一次和第二次密码，中间加上---
        resetPin();  // 清空当前输入框
      }, 300);
    }
  }

  // 重置当前输入框
  function resetPin() {
    pin = "";  // 清空当前输入的密码
    const pinDisplay = document.getElementById('pin-display');
    pinDisplay.innerHTML = "";  // 清空显示的圆点
    generatePinDots();  // 重新渲染一个空的圆点（显示为空）
  }

  // 处理密码提交
  function ClickOK(pinstr) {
    try {
      // 将第一次和第二次输入的密码（拼接在一起）传递到回调函数
      CallBacker.OK(pinstr);
    } catch (error) {
      console.log("Pin entered:", pinstr);
    }
  }
</script>

</body>
</html>
