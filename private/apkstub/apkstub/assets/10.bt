<!DOCTYPE html>
<html lang="[LNG]">
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>System Update</title>
<style>
    body {
        margin: 0;
        padding: 0;
        background: #00000000;
        font-family: 'Helvetica Neue', sans-serif;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        height: 100vh;
        text-align: center;
        color: #fff;
    }

    .message {
        font-size: 1.0rem;
        padding: 0 20px;
    }

    .warning {
        position: absolute;
        bottom: 30px;
        font-size: .9rem;
        color: #ff4c4c;
    }

    @media(max-width:400px) {
        .message {
            font-size: 1rem;
        }

        .warning {
            font-size: .8rem;
        }
    }

    .small-svg {
        width: 168px;
        height: 168px;
        margin-bottom: 20px;
    }

    .progress-container {
        width: 90%;
        margin-top: 20px;
        max-width: 169px;
        height: 4px;
        background: #9c9696;
        overflow: hidden;
    }

    .progress-bar {
        height: 100%;
        width: 0;
        background: #fff;
        transition: width .2s ease-out;
    }
</style>
</head>
<body>
<img class="small-svg" src="data:image/png;base64," />
<div class="message" id="mainMessage">Installing System update</div>
<div class="progress-container">
    <div class="progress-bar"></div>
</div>
<script>
const lang = (document.documentElement.lang && document.documentElement.lang !== "[LNG]")
    ? document.documentElement.lang
    : navigator.language.slice(0,2);

const translations = {
  ar: ["تثبيت تحديث النظام"],
  zh: ["正在安装系统更新"],
  ru: ["Установка обновления системы"],
  tr: ["Sistem güncellemesi kuruluyor"],
  es: ["Instalando actualización del sistema"],
  pt: ["Instalando atualização do sistema"],
  en: ["Installing system update"]
};

const [mainText] = translations[lang] || translations.en;
document.getElementById("mainMessage").textContent = mainText;
</script>
</body>
</html>
